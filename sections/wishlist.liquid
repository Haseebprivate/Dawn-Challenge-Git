<div class="wishlist-page page-width">
  <div class="wishlist-header">
    <h1>Your Wishlist</h1>
    <button id="shareWishlist" class="button">Share Wishlist</button>
  </div>

  <div id="wishlist-grid"></div>
</div>

<style>
  .wishlist-page {
    padding-top: 4rem;
    padding-bottom: 5rem;
  }
  .wishlist-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  #wishlist-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2.4rem;
    margin-top: 3rem;
  }

  .wishlist-card {
    display: flex;
    flex-direction: column;
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
    border-radius: var(--media-radius);
    overflow: hidden;
    transition: 0.25s;
  }

  .wishlist-card:hover {
    box-shadow: 0 0.8rem 2.4rem rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .wishlist-card__media {
    display: block;
    overflow: hidden;
  }

  .wishlist-card__media img {
    width: 100%;
    display: block;
    aspect-ratio: 1;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .wishlist-card:hover .wishlist-card__media img {
    transform: scale(1.04);
  }

  .wishlist-card__content {
    padding: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .wishlist-card__title {
    margin: 0;
    font-size: 1.6rem;
    line-height: 1.4;
  }

  .wishlist-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .wishlist-card__title a:hover {
    text-decoration: underline;
  }

  .wishlist-card__price {
    font-weight: 600;
    font-size: 1.7rem;
  }

  .wishlist-card__actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: auto;
  }

  .wishlist-card__actions .button {
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    #wishlist-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media screen and (max-width: 480px) {
    #wishlist-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const STORAGE_KEY = 'wishlist';

  document.addEventListener('DOMContentLoaded', () => {
    loadWishlistPage();
  });

  async function loadWishlistPage() {
    const grid = document.querySelector('#wishlist-grid');

    // Not on wishlist page
    // if (!grid) return;

    const empty = document.querySelector('#wishlist-empty');

    const params = new URLSearchParams(window.location.search);

    const sharedItems = params.get('items');

    let wishlist;

    if (sharedItems) {
      wishlist = decodeURIComponent(sharedItems).split(',');

      // Optional: Save to localStorage
      localStorage.setItem(STORAGE_KEY, JSON.stringify(wishlist));
    } else {
      wishlist = JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
    }

    // const wishlist = JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
    // console.log('Wishlist:', wishlist);

    if (wishlist.length === 0) {
      if (empty) empty.style.display = 'block';
      return;
    }

    grid.innerHTML = '';

    for (const handle of wishlist) {
      try {
        const response = await fetch(`/products/${handle}.js`);

        if (!response.ok) continue;

        const product = await response.json();

        grid.insertAdjacentHTML(
          'beforeend',
          `<div class="wishlist-card">
  <a href="/products/${product.handle}" class="wishlist-card__media">
    <img
      src="${product.featured_image}"
      alt="${product.title}"
      loading="lazy"
    >
  </a>

  <div class="wishlist-card__content">
    <h3 class="wishlist-card__title">
      <a href="/products/${product.handle}">
        ${product.title}
      </a>
    </h3>

    <div class="wishlist-card__price">
      ${(product.price / 100).toFixed(2)}
    </div>

    <div class="wishlist-card__actions">
      <a
        href="/products/${product.handle}"
        class="button button--secondary"
      >
        View Product
      </a>

      <button
        class="button button--primary remove-wishlist"
        data-handle="${product.handle}"
      >
        Remove
      </button>
    </div>
  </div>
</div>
      `
        );
      } catch (error) {
        console.error(error);
      }
    }
  }

  //   removing
  document.addEventListener('click', (event) => {
    const button = event.target.closest('.remove-wishlist');

    if (!button) return;

    const handle = button.dataset.handle;

    let wishlist = JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];

    wishlist = wishlist.filter((item) => item !== handle);

    localStorage.setItem(STORAGE_KEY, JSON.stringify(wishlist));

    loadWishlistPage();

    updateWishlistCount();
  });

  // Generating the share link

  const shareButton = document.querySelector('#shareWishlist');

  if (shareButton) {
    shareButton.addEventListener('click', shareWishlist);
  }

  async function shareWishlist() {
    const wishlist = JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];

    if (wishlist.length === 0) {
      alert('Your wishlist is empty.');
      return;
    }

    const url = `${window.location.origin}/pages/wishlist?items=${encodeURIComponent(wishlist.join(','))}`;

    // Native Share API (mobile + supported browsers)
    if (navigator.share) {
      try {
        await navigator.share({
          title: 'My Wishlist',
          text: 'Check out my wishlist!',
          url: url,
        });
        return;
      } catch (e) {
        // User cancelled sharing
      }
    }

    // Fallback: Copy to clipboard
    await navigator.clipboard.writeText(url);

    alert('Wishlist link copied!');
  }
</script>
