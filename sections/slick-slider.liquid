<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js" defer></script>

{{ 'slick.css' | asset_url | stylesheet_tag }}
{{ 'slick-theme.css' | asset_url | stylesheet_tag }}

<script src="{{ 'slick.min.js' | asset_url }}" defer></script>

<div class="page-width">
  <div class="your-class">
    {% for block in section.blocks %}
      {% if block.type == 'image_picker' %}
        <div class="slick-slide">
          <img src="{{ block.settings.slide_image |  image_url  }}" alt="">
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

<style>
  /* ========================================
   Slider Container
======================================== */

  .margin-top-bottom {
    margin-top: 40px;
  }

  /* Prevent slides from overflowing rounded corners */
  .slick-list {
    border-radius: 8px;
    overflow: hidden !important;
  }

  /* ========================================
   Slide Images
======================================== */

  .your-class .slick-slide img {
    display: block;
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: 8px;
  }

  /* ========================================
   Navigation Arrows
======================================== */

  /* Hide Slick's default arrow icons */
  .slick-prev::before,
  .slick-next::before {
    display: none;
  }

  /* Base arrow styles */
  .slick-prev,
  .slick-next {
    position: absolute;
    color: white !important;
    z-index: 2;
  }

  /* Keep arrow color on hover */
  .slick-prev:hover,
  .slick-next:hover {
    color: white;
  }

  /* Previous Arrow */
  .slick-prev {
    left: 0;
    transform: translate(-10px, -10px);
  }

  /* Next Arrow */
  .slick-next {
    right: 0;
    transform: translate(10px, -10px);
  }

  /* Circular background behind arrows */
  .slick-prev::after,
  .slick-next::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;

    width: 60px;
    height: 60px;

    border: 1px dashed #ed04ab;
    border-radius: 50%;
    background: #ed04ab;

    transform: translate(-20px, -20px);
    z-index: -1;

    border: 6px solid white;
    box-sizing: border-box;
  }

  /* ========================================
   Pagination Dots
======================================== */

  /* .slick-dots li button::before {
    content: '';
    width: 10px;
    height: 10px;

    background: #ccc;
    border-radius: 50%;
    opacity: 1;
  } */

  .slick-dots {
    display: flex !important;
    /* justify-content: center; */
    gap: 8px;
  }

  .slick-dots li {
    width: auto;
    margin: 0;
  }

  .slick-dots li {
    margin: 0;
  }

  /* dots pill on active */

  .slick-dots li button::before {
    display: none;
  }

  .slick-dots li.slick-active button::before {
    display: none;
  }
  .slick-dots li button {
    content: '';
    display: inline-block;
    width: 10px;
    height: 10px;
    margin: 0 auto;
    border-radius: 999px;
    background: white;
    opacity: 1;
    transition: all 0.3s ease;
  }

  .slick-dots li.slick-active button {
    width: 20px;
    background-color: #ed04ab;
  }

  .your-class ul {
    left: 40px;
    bottom: 40px;
  }

  .slick-dotted.slick-slider {
    margin-bottom: 0px;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    $('.your-class').slick({
      dots: true,
      arrows: true,
      autoplay: true,
      prevArrow: `
    <button type="button" class="slick-prev">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
</svg>

    </button>
  `,
      nextArrow: `
    <button type="button" class="slick-next">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
  <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
</svg>

    </button>
  `,
    });
  });
</script>

{% schema %}
{
  "name": "Slick Slider",
  "class": "margin-top-bottom",
  "blocks": [
    {
      "name": "slide",
      "type": "image_picker",
      "settings": [
        {
          "type": "image_picker",
          "id": "slide_image",
          "label": "slide"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Slick Slider",
      "settings": {}
    }
  ]
}
{% endschema %}
